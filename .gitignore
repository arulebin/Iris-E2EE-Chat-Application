# Secrets — never commit
.env
.env.*
!.env.example

# Backend build artifacts (covered by backend/.gitignore too, but explicit at root is safer)
backend/target/
backend/data/

# Frontend build artifacts
frontend/dist/
frontend/node_modules/

# IDE
.idea/
*.iml
.vscode/

# Untracked/Unwanted Root files
front-end-logs.txt
node_modules/
package-lock.json
package.json
PROGRESS.md
SUMMARY.md
.claude/
